# Application Settings
APP_NAME=Virtual Environment Platform
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
API_V1_PREFIX=/api/v1

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=True

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/virtualenv_db
MONGODB_URL=mongodb://localhost:27017/virtualenv_db
REDIS_URL=redis://localhost:6379/0

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=virtualenv-storage
S3_BUCKET_VIDEOS=virtualenv-videos
S3_BUCKET_SCENES=virtualenv-scenes
S3_BUCKET_DATASETS=virtualenv-datasets

# Google Cloud Configuration (Alternative to AWS)
GCP_PROJECT_ID=your-project-id
GCP_BUCKET_NAME=virtualenv-storage
GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_TRACK_STARTED=True
CELERY_TASK_TIME_LIMIT=7200

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4096

# Anthropic Configuration
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODEL=claude-3-opus-20240229

# ElevenLabs Configuration
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=default-voice-id

# Stripe Configuration (Payment)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=noreply@virtualenv.ai
EMAILS_FROM_NAME=Virtual Environment Platform

# CORS Configuration
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Processing Configuration
MAX_VIDEO_SIZE_MB=5000
MAX_VIDEO_DURATION_SECONDS=7200
SUPPORTED_VIDEO_FORMATS=mp4,mov,avi,mkv
FRAME_EXTRACTION_FPS=30
NERF_TRAINING_ITERATIONS=30000
GAUSSIAN_SPLATTING_ITERATIONS=30000

# GPU Configuration
CUDA_VISIBLE_DEVICES=0
TORCH_CUDA_ARCH_LIST=8.0;8.6;8.9

# Monitoring
SENTRY_DSN=your-sentry-dsn
PROMETHEUS_PORT=9090

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Feature Flags
ENABLE_VOICE_CLONING=True
ENABLE_AI_CHAT=True
ENABLE_DATASET_MARKETPLACE=True
ENABLE_VR_STREAMING=True

# Subscription Tiers
FREE_TIER_PROJECTS=3
FREE_TIER_STORAGE_GB=10
BASIC_TIER_PROJECTS=10
BASIC_TIER_STORAGE_GB=100
PRO_TIER_PROJECTS=50
PRO_TIER_STORAGE_GB=500

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log